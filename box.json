        },
        {
          "id": "RXGYG_Token_1",
          "name": "账号1 Token（自动抓取）",
          "val": "",
          "type": "textarea",
          "autoGrow": true,
          "rows": 2,
          "desc": "由 GetToken 脚本自动抓取写入，也可手动粘贴。"
        },
        {
          "id": "RXGYG_Token_2",
          "name": "账号2 Token（手动填写）",
          "val": "",
          "type": "textarea",
          "autoGrow": true,
          "rows": 2,
          "desc": "手动粘贴账号2的 JWT Token。"
        },
        {
          "id": "RXGYG_Token_3",
          "name": "账号3 Token（手动填写）",
          "val": "",
          "type": "textarea",
          "autoGrow": true,
          "rows": 2,
          "desc": "手动粘贴账号3的 JWT Token。"
        },
        {
          "id": "RXGYG_ExpireWarning",
          "name": "Token 过期预警（小时）",
          "val": 6,
          "type": "text",
          "desc": "Token 剩余时间低于此值时推送提醒，默认 6 小时。"
        }
      ],
      "author": "@辣堡",
      "repo": "https://github.com/a974881061",
